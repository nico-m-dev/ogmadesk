{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "OgmaDesk",
  "version": "1.0.2",
  "identifier": "com.ogmadesk.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OgmaDesk",
        "width": 1550,
        "height": 1050,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU2NzJFN0JERTI0RTlDOUUKUldTZW5FN2l2ZWR5VnNaVUVuWWczeEIxanViYkVZNG9hd0o0aEt0L0JYRUpmUmI3SVFMWldXelIK",
      "endpoints": [
        "https://github.com/nico-m-dev/ogmadesk/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}